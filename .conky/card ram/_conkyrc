#!/usr/bin/conky -d -c
##	.conkyrc configuration
alignment top_middle
background yes
border_margin 5
border_width 5
color0 555555			#
color1 FCAF3E			# zolty
color2 2a2a2a			# braz
color3 a82553			# rozowy f71f84
color4 5e1014			# bordowy
color5 64574e			# braz
color6 2a2a2a			# szary
color7 8888CC			#  (COOL)
color8 9d9c61			# zolto-szary
color9 525276			# niebiesko-szary
cpu_avg_samples 2
default_color 000000		# szary 5f5f5f
default_outline_color 000000 	# Black
default_shade_color 000000	# Black
double_buffer yes
draw_borders no
draw_graph_borders no
draw_outline no
draw_shades no
gap_x -255
gap_y 35
max_specials 1024
max_user_text 10000
maximum_width 400
minimum_size 230 0
net_avg_samples 2
no_buffers yes
override_utf8_locale yes
own_window yes
own_window_colour FFFFFF
own_window_hints undecorated,below,sticky,skip_taskbar,skip_pager
own_window_transparent no
own_window_type normal 	## normal
pad_percents 2
short_units yes
stippled_borders 3
text_buffer_size 8000
total_run_times 0
update_interval 1.0
uppercase no
use_spacer right
use_xft yes
xftalpha 1
xftfont Freesans:pixelsize=9
own_window_argb_value 255
own_window_argb_visual no
TEXT
${font Zegoe UI:size=12}${color #FF4081}MEMORY
${font Zegoe:size=10}${color #6a6a6a}
RAM ${mem}
${membar 5,}
${top_mem name 1} $alignr ${top_mem mem_res 1}
${top_mem name 2} $alignr ${top_mem mem_res 2}
${top_mem name 3} $alignr ${top_mem mem_res 3}
${top_mem name 4} $alignr ${top_mem mem_res 4}
${top_mem name 5} $alignr ${top_mem mem_res 5}
